{
  "name": "OLTP API Environment",
  "image": "mcr.microsoft.com/devcontainers/dotnet:8.0",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [5258],
  "postCreateCommand": "cd ConferenceAttendees.Api && docker compose up --build -d",
  "portsAttributes": {
    "5258": {
      "label": "Swagger API",
      "onAutoForward": "openBrowser"
    }
  }
}
